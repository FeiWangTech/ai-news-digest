# Gmail SMTP sender account
GMAIL_SENDER=your-email@gmail.com

# 16-character Gmail App Password without spaces
GMAIL_APP_PW=your16characterapppassword

# Recipient used by the scheduled GitHub Actions workflow
DIGEST_RECIPIENT=recipient@example.com

# Optional frontend API URL
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000